        </mxCell>

        <!-- 決策：是否連線成功？ -->
        <mxCell id="40" value="連線成功？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="309" y="300" width="170" height="70" as="geometry" />
