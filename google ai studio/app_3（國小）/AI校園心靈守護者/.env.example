# Optional. Current demo is local-first and works without Gemini.
GEMINI_API_KEY=""

# Optional. Point node/alert care cues to App 1's shared local bridge.
# Leave empty to use http://localhost:3200 and fallback cleanly when the bridge is offline.
VITE_ARDUINO_BRIDGE_URL="http://localhost:3200"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=""
