# Optional. Without a key, AI routes use the local fallback engine and the UI labels it clearly.
GEMINI_API_KEY=""

# Local bridge and production single-server port.
BRIDGE_PORT=3200

# Optional Arduino Serial settings. Without ARDUINO_PORT, the bridge stays in demo/fallback mode.
# App 1 exposes /api/robot/command, and App 2/App 3 can share this bridge via VITE_ARDUINO_BRIDGE_URL.
ARDUINO_BAUD=115200
# ARDUINO_PORT=/dev/cu.usbmodemXXXX
